#!/bin/bash
#
# Skylens Node installer for EL9 / RHEL 9 / Rocky 9 / Alma 9
# - Builds skylens-node from local source
# - Runs service as non-root user tdcadmin
# - Uses systemd AmbientCapabilities for port 443
# - Writes a clean config.yaml every run
# - Repairs first-boot auth seed when roles exist but admin user does not
#

set -Eeuo pipefail

NATS_VERSION="2.10.24"
GO_VERSION="1.24.0"
SERVICE_USER="tdcadmin"
SERVICE_GROUP="tdcadmin"

HTTPS_PORT=443
OPT_DIR="/opt/skylens"
CONFIG_DIR="${OPT_DIR}/configs"
CONFIG_FILE="${CONFIG_DIR}/config.yaml"
BINARY_PATH="${OPT_DIR}/skylens-node"
CERT_DIR="/etc/skylens/certs"
CERT_FILE="${CERT_DIR}/skylens.crt"
KEY_FILE="${CERT_DIR}/skylens.key"
LOG_FILE="/var/log/skylens-install.log"
SYSTEMD_UNIT="/etc/systemd/system/skylens-node.service"

if [[ -n "${SUDO_USER:-}" ]]; then
    USER_HOME="$(getent passwd "$SUDO_USER" | cut -d: -f6)"
else
    USER_HOME="$HOME"
fi
BUILD_DIR="${USER_HOME}/skylens"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

PHASE_TOTAL=10
PHASE_CURRENT=0

log() {
    mkdir -p "$(dirname "$LOG_FILE")"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"
}

info() {
    echo -e "${BLUE}[INFO]${NC} $*"
    log "INFO: $*"
}

ok() {
    echo -e "${GREEN}[ OK ]${NC} $*"
    log "OK: $*"
}

warn() {
    echo -e "${YELLOW}[WARN]${NC} $*"
    log "WARN: $*"
}

fail() {
    echo -e "${RED}[FAIL]${NC} $*"
    log "FAIL: $*"
}

die() {
    fail "$*"
    echo
    echo "Last 30 log lines:"
    tail -30 "$LOG_FILE" 2>/dev/null | sed 's/^/  /'
    exit 1
}

phase() {
    ((PHASE_CURRENT++)) || true
    echo
    echo -e "${CYAN}${BOLD}[${PHASE_CURRENT}/${PHASE_TOTAL}] $*${NC}"
    echo -e "${CYAN}$(printf '%.0s─' {1..68})${NC}"
    log "===== PHASE ${PHASE_CURRENT}/${PHASE_TOTAL}: $* ====="
}

cleanup() {
    [[ -n "${TMP_BINARY:-}" && -f "${TMP_BINARY:-}" ]] && rm -f "$TMP_BINARY"
}
trap cleanup EXIT

run_cmd() {
    local desc="$1"
    shift
    local tmpout
    tmpout="$(mktemp /tmp/skylens-cmd-XXXXXX)"
    info "$desc"
    if "$@" >"$tmpout" 2>&1; then
        cat "$tmpout" >> "$LOG_FILE"
        tail -5 "$tmpout" | sed 's/^/    /'
        rm -f "$tmpout"
        return 0
    fi
    local rc=$?
    cat "$tmpout" >> "$LOG_FILE"
    tail -20 "$tmpout" | sed 's/^/    /'
    rm -f "$tmpout"
    return "$rc"
}

try_cmd() {
    local desc="$1"
    shift
    local tmpout
    tmpout="$(mktemp /tmp/skylens-cmd-XXXXXX)"
    info "$desc"
    if "$@" >"$tmpout" 2>&1; then
        cat "$tmpout" >> "$LOG_FILE"
        tail -3 "$tmpout" | sed 's/^/    /'
        rm -f "$tmpout"
        return 0
    fi
    local rc=$?
    cat "$tmpout" >> "$LOG_FILE"
    tail -10 "$tmpout" | sed 's/^/    /'
    rm -f "$tmpout"
    return "$rc"
}

generate_password() {
    openssl rand -base64 24 | tr -d '\n'
}

generate_jwt_secret() {
    openssl rand -base64 48 | tr -d '\n'
}

psql_super() {
    local sql="$1"
    su -s /bin/bash - postgres -c "/usr/pgsql-16/bin/psql -v ON_ERROR_STOP=1 -tAc \"$sql\"" >> "$LOG_FILE" 2>&1
}

psql_app() {
    local sql="$1"
    PGPASSWORD="$DB_PASSWORD" /usr/pgsql-16/bin/psql \
        -h 127.0.0.1 \
        -U skylens \
        -d skylens \
        -v ON_ERROR_STOP=1 \
        -tAc "$sql"
}

require_root() {
    [[ $EUID -eq 0 ]] || die "Run as root"
}

require_el9() {
    grep -qiE 'rocky|rhel|red hat|alma|centos' /etc/os-release 2>/dev/null || die "This installer requires EL9"
    local major
    major="$(rpm -E '%{rhel}' 2>/dev/null || echo 0)"
    [[ "$major" == "9" ]] || die "This installer requires EL9; detected EL${major}"
}

wait_for_port() {
    local host="$1"
    local port="$2"
    local tries="${3:-30}"
    local i
    for ((i=1; i<=tries; i++)); do
        if timeout 1 bash -c ">/dev/tcp/${host}/${port}" 2>/dev/null; then
            return 0
        fi
        sleep 1
    done
    return 1
}

wait_for_health() {
    local tries="${1:-30}"
    local i
    for ((i=1; i<=tries; i++)); do
        if curl -kfsS --connect-timeout 3 "https://127.0.0.1:${HTTPS_PORT}/health" 2>/dev/null | grep -q '"status"'; then
            return 0
        fi
        sleep 2
    done
    return 1
}

wait_for_db() {
    local tries="${1:-30}"
    local i
    for ((i=1; i<=tries; i++)); do
        if su -s /bin/bash - postgres -c "/usr/pgsql-16/bin/pg_isready -q"; then
            return 0
        fi
        sleep 2
    done
    return 1
}

write_config() {
    install -d -m 0755 "$CONFIG_DIR"
    cat > "$CONFIG_FILE" <<EOF
# Skylens Node Configuration
# Generated by install-node.sh on $(date -Is)

server:
  https_port: ${HTTPS_PORT}
  tls_cert_file: ${CERT_FILE}
  tls_key_file: ${KEY_FILE}
  allowed_origins: ["*"]

nats:
  url: "nats://127.0.0.1:4222"

database:
  host: "127.0.0.1"
  port: 5432
  name: "skylens"
  user: "skylens"
  password: "${DB_PASSWORD}"
  ssl_mode: "disable"

redis:
  url: "redis://127.0.0.1:6379"

detection:
  lost_threshold_sec: 1800
  evict_after_min: 30
  tap_offline_threshold_sec: 90
  trust_decay_rate: 0.1
  max_history_hours: 8760
  max_displayed_drones: 500
  spoof_check_enabled: true
  db_worker_count: 8
  db_queue_size: 5000
  single_tap_mode: true
  single_tap_min_observations: 5
  single_tap_min_time_span_sec: 30
  single_tap_min_mobility: 0.5

propagation:
  global_environment: "open_field"
  tap_environments: {}
  tap_rssi_offsets: {}

auth:
  enabled: true
  jwt_secret: "${JWT_SECRET}"
  secure_cookies: true

telegram:
  enabled: false
  bot_token: ""
  chat_id: ""
  notify_new_drone: true
  notify_spoofing: true
  notify_drone_lost: true
  notify_tap_status: true

tak:
  enabled: false
  address: ""
  use_tls: true
  cert_file: ""
  key_file: ""
  ca_file: ""
  rate_limit_sec: 3
  stale_seconds: 30
  send_controllers: false
EOF
    chmod 0640 "$CONFIG_FILE"
    chown root:"$SERVICE_GROUP" "$CONFIG_FILE"
}

validate_config_yaml() {
    python3 - "$CONFIG_FILE" <<'PY'
import sys, yaml
path = sys.argv[1]
with open(path, 'r', encoding='utf-8') as f:
    yaml.safe_load(f)
print("YAML OK")
PY
}

write_service_unit() {
    cat > "$SYSTEMD_UNIT" <<EOF
[Unit]
Description=Skylens Node - UAV Airspace Monitor
Documentation=https://github.com/K13094/skylens
After=network-online.target nats.service postgresql-16.service redis.service
Wants=network-online.target
Requires=nats.service postgresql-16.service redis.service

[Service]
Type=simple
User=${SERVICE_USER}
Group=${SERVICE_GROUP}
WorkingDirectory=${OPT_DIR}
ExecStartPre=/usr/bin/test -x ${BINARY_PATH}
ExecStartPre=/usr/bin/test -r ${CONFIG_FILE}
ExecStartPre=/usr/bin/test -r ${CERT_FILE}
ExecStartPre=/usr/bin/test -r ${KEY_FILE}
ExecStart=${BINARY_PATH} -config ${CONFIG_FILE} -log-format json -log-level info
ExecReload=/bin/kill -HUP \$MAINPID
Restart=always
RestartSec=5
TimeoutStartSec=30
TimeoutStopSec=30
LimitNOFILE=65536
LimitNPROC=4096
NoNewPrivileges=true
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=${OPT_DIR}
StandardOutput=journal
StandardError=journal
SyslogIdentifier=skylens-node
Environment=GOMAXPROCS=4

[Install]
WantedBy=multi-user.target
EOF
}

configure_selinux() {
    if ! command -v getenforce >/dev/null 2>&1; then
        return 0
    fi

    local mode
    mode="$(getenforce 2>/dev/null || true)"
    info "SELinux mode: ${mode}"

    command -v restorecon >/dev/null 2>&1 && restorecon -Rv /etc/skylens "$OPT_DIR" >> "$LOG_FILE" 2>&1 || true

    if command -v semanage >/dev/null 2>&1; then
        semanage fcontext -a -t bin_t "${BINARY_PATH}" >> "$LOG_FILE" 2>&1 || \
        semanage fcontext -m -t bin_t "${BINARY_PATH}" >> "$LOG_FILE" 2>&1 || true
        restorecon -v "${BINARY_PATH}" >> "$LOG_FILE" 2>&1 || true
    fi
}

repair_auth_seed_if_needed() {
    if ! psql_app "SELECT 1" >/dev/null 2>&1; then
        warn "Skipping auth bootstrap check; app DB connection failed"
        return 0
    fi

    local roles_exists users_exists
    roles_exists="$(psql_app "SELECT to_regclass('public.roles') IS NOT NULL;" 2>/dev/null | xargs || true)"
    users_exists="$(psql_app "SELECT to_regclass('public.users') IS NOT NULL;" 2>/dev/null | xargs || true)"

    [[ "$roles_exists" == "t" && "$users_exists" == "t" ]] || return 0

    local role_count user_count admin_count
    role_count="$(psql_app "SELECT COUNT(*) FROM roles;" 2>/dev/null | xargs || echo 0)"
    user_count="$(psql_app "SELECT COUNT(*) FROM users;" 2>/dev/null | xargs || echo 0)"
    admin_count="$(psql_app "SELECT COUNT(*) FROM users WHERE username='admin';" 2>/dev/null | xargs || echo 0)"

    info "Auth state: roles=${role_count} users=${user_count} admin=${admin_count}"

    if [[ "$role_count" -gt 0 && "$admin_count" -eq 0 && "$user_count" -eq 0 ]]; then
        warn "Detected partial auth seed (roles exist, admin missing, no users). Resetting auth tables for clean reseed."
        psql_app "TRUNCATE TABLE user_tap_access, audit_log, sessions, role_permissions, permissions, users, roles RESTART IDENTITY CASCADE;" \
            >> "$LOG_FILE" 2>&1 || die "Failed to reset auth tables"
        systemctl restart skylens-node >> "$LOG_FILE" 2>&1 || die "Failed to restart skylens-node after auth reset"
        sleep 5
    fi
}

echo "=== Skylens Node Install $(date) ===" > "$LOG_FILE"
require_root
require_el9

IS_RHEL=false
if grep -qi 'red hat\|rhel' /etc/os-release 2>/dev/null; then
    IS_RHEL=true
fi

echo
echo -e "${CYAN}${BOLD}╔══════════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}${BOLD}║                 Skylens Node Installer                      ║${NC}"
echo -e "${CYAN}${BOLD}║                      EL9 / RHEL9                            ║${NC}"
echo -e "${CYAN}${BOLD}╚══════════════════════════════════════════════════════════════╝${NC}"
echo
echo "Detected OS: $(cat /etc/redhat-release 2>/dev/null || echo unknown)"
echo "Build dir:    ${BUILD_DIR}"
echo "Binary path:  ${BINARY_PATH}"
echo

DEFAULT_DB_PASS="$(generate_password)"
DEFAULT_JWT_SECRET="$(generate_jwt_secret)"

read -rp "PostgreSQL password for user 'skylens' [auto-generate]: " DB_PASSWORD
DB_PASSWORD="${DB_PASSWORD:-$DEFAULT_DB_PASS}"

read -rp "JWT secret [auto-generate]: " JWT_SECRET
JWT_SECRET="${JWT_SECRET:-$DEFAULT_JWT_SECRET}"

echo
echo -e "${CYAN}Configuration summary${NC}"
echo "  HTTPS port: ${HTTPS_PORT}"
echo "  DB pass:    ${DB_PASSWORD:0:4}****"
echo "  JWT:        ${JWT_SECRET:0:8}..."
echo "  Build dir:  ${BUILD_DIR}"
echo "  RHEL:       ${IS_RHEL}"
echo
read -rp "Proceed? (y/n) [y]: " CONFIRM
CONFIRM="${CONFIRM:-y}"
[[ "$CONFIRM" =~ ^[Yy]$ ]] || exit 0

phase "Base packages"

if [[ "$IS_RHEL" == true ]]; then
    if command -v subscription-manager >/dev/null 2>&1; then
        try_cmd "Checking RHEL subscription status..." subscription-manager status || true
        dnf config-manager --set-enabled crb >> "$LOG_FILE" 2>&1 || \
        subscription-manager repos --enable "codeready-builder-for-rhel-9-$(arch)-rpms" >> "$LOG_FILE" 2>&1 || true
    fi
fi

if ! rpm -q epel-release >/dev/null 2>&1; then
    try_cmd "Installing EPEL..." dnf install -y https://dl.fedoraproject.org/pub/epel/epel-release-latest-9.noarch.rpm || true
fi

run_cmd "Refreshing DNF metadata..." dnf makecache

PKGS=(
    curl wget tar gzip git jq openssl python3 python3-pip
    dnf-plugins-core policycoreutils policycoreutils-python-utils
    firewalld tuned shadow-utils setcap hostname which
)

for pkg in "${PKGS[@]}"; do
    rpm -q "$pkg" >/dev/null 2>&1 || run_cmd "Installing ${pkg}..." dnf install -y "$pkg"
done

ok "Base packages ready"

phase "Service account and directories"

if ! id "$SERVICE_USER" >/dev/null 2>&1; then
    run_cmd "Creating ${SERVICE_USER} user..." useradd -r -m -d "/home/${SERVICE_USER}" -s /bin/bash "$SERVICE_USER"
else
    ok "User ${SERVICE_USER} already exists"
fi

getent group "$SERVICE_GROUP" >/dev/null 2>&1 || groupadd "$SERVICE_GROUP" >> "$LOG_FILE" 2>&1 || true
usermod -aG "$SERVICE_GROUP" "$SERVICE_USER" >> "$LOG_FILE" 2>&1 || true

install -d -m 0755 "$OPT_DIR" "$CONFIG_DIR" "$CERT_DIR"
install -d -m 0755 /var/log/skylens
chown -R root:root "$OPT_DIR"
chown -R root:root /etc/skylens
chmod 0755 /etc/skylens "$CERT_DIR"
ok "Directories ready"

phase "PostgreSQL 16"

if ! rpm -q pgdg-redhat-repo >/dev/null 2>&1; then
    run_cmd "Installing PGDG repository..." dnf install -y --nogpgcheck https://download.postgresql.org/pub/repos/yum/reporpms/EL-9-x86_64/pgdg-redhat-repo-latest.noarch.rpm
fi

dnf -y module disable postgresql >> "$LOG_FILE" 2>&1 || true
run_cmd "Installing PostgreSQL 16..." dnf install -y postgresql16-server postgresql16

if [[ ! -d /var/lib/pgsql/16/data/base ]]; then
    run_cmd "Initializing PostgreSQL 16..." /usr/pgsql-16/bin/postgresql-16-setup initdb
else
    ok "PostgreSQL already initialized"
fi

systemctl enable --now postgresql-16 >> "$LOG_FILE" 2>&1 || die "Failed to start PostgreSQL 16"
wait_for_db 30 || die "PostgreSQL did not become ready"

PG_HBA="/var/lib/pgsql/16/data/pg_hba.conf"
cat > "$PG_HBA" <<'EOF'
# TYPE  DATABASE        USER            ADDRESS                 METHOD
local   all             postgres                                peer
local   all             all                                     scram-sha-256
host    all             all             127.0.0.1/32            scram-sha-256
host    all             all             ::1/128                 scram-sha-256
EOF
chown postgres:postgres "$PG_HBA"
chmod 0600 "$PG_HBA"
systemctl restart postgresql-16 >> "$LOG_FILE" 2>&1 || die "Failed to restart PostgreSQL 16 after pg_hba update"
wait_for_db 30 || die "PostgreSQL failed after pg_hba update"

if ! su -s /bin/bash - postgres -c "/usr/pgsql-16/bin/psql -tAc \"SELECT 1 FROM pg_roles WHERE rolname='skylens'\"" 2>/dev/null | grep -q 1; then
    su -s /bin/bash - postgres -c "/usr/pgsql-16/bin/psql -v ON_ERROR_STOP=1 -v dbpass='${DB_PASSWORD//\'/\'\'}' <<'SQL'
CREATE ROLE skylens WITH LOGIN PASSWORD :'dbpass';
SQL" >> "$LOG_FILE" 2>&1 || die "Failed to create PostgreSQL role skylens"
    ok "Created PostgreSQL role skylens"
else
    su -s /bin/bash - postgres -c "/usr/pgsql-16/bin/psql -v ON_ERROR_STOP=1 -v dbpass='${DB_PASSWORD//\'/\'\'}' <<'SQL'
ALTER ROLE skylens WITH LOGIN PASSWORD :'dbpass';
SQL" >> "$LOG_FILE" 2>&1 || die "Failed to update PostgreSQL role password"
    ok "Updated PostgreSQL role skylens password"
fi

if ! su -s /bin/bash - postgres -c "/usr/pgsql-16/bin/psql -tAc \"SELECT 1 FROM pg_database WHERE datname='skylens'\"" 2>/dev/null | grep -q 1; then
    su -s /bin/bash - postgres -c "/usr/pgsql-16/bin/psql -v ON_ERROR_STOP=1 <<'SQL'
CREATE DATABASE skylens OWNER skylens;
SQL" >> "$LOG_FILE" 2>&1 || die "Failed to create PostgreSQL database skylens"
    ok "Created database skylens"
else
    ok "Database skylens already exists"
fi

phase "Redis"

if ! rpm -q redis >/dev/null 2>&1; then
    run_cmd "Installing Redis..." dnf install -y redis
fi

REDIS_CONF="/etc/redis/redis.conf"
[[ -f /etc/redis.conf ]] && REDIS_CONF="/etc/redis.conf"

if [[ -f "$REDIS_CONF" ]]; then
    sed -ri 's/^[#[:space:]]*bind .*/bind 127.0.0.1 ::1/' "$REDIS_CONF"
    sed -ri 's/^[#[:space:]]*protected-mode .*/protected-mode yes/' "$REDIS_CONF"
    sed -ri 's/^[#[:space:]]*port .*/port 6379/' "$REDIS_CONF"
fi

systemctl enable --now redis >> "$LOG_FILE" 2>&1 || die "Failed to start Redis"
ok "Redis ready"

phase "NATS"

if [[ ! -x /usr/local/bin/nats-server ]] || ! /usr/local/bin/nats-server --version 2>&1 | grep -q "${NATS_VERSION}"; then
    run_cmd "Downloading NATS ${NATS_VERSION}..." wget -q "https://github.com/nats-io/nats-server/releases/download/v${NATS_VERSION}/nats-server-v${NATS_VERSION}-linux-amd64.tar.gz" -O /tmp/nats-server.tar.gz
    tar -xzf /tmp/nats-server.tar.gz -C /tmp >> "$LOG_FILE" 2>&1 || die "Failed to extract NATS"
    install -m 0755 "/tmp/nats-server-v${NATS_VERSION}-linux-amd64/nats-server" /usr/local/bin/nats-server
    rm -rf /tmp/nats-server.tar.gz "/tmp/nats-server-v${NATS_VERSION}-linux-amd64"
    ok "NATS installed"
else
    ok "NATS already installed"
fi

id nats >/dev/null 2>&1 || useradd -r -s /sbin/nologin nats >> "$LOG_FILE" 2>&1 || true
install -d -m 0755 /etc/nats /var/log/nats
chown nats:nats /var/log/nats

cat > /etc/nats/nats.conf <<'EOF'
port: 4222
http_port: 8222
server_name: "skylens-node"
log_file: "/var/log/nats/nats.log"
EOF

cat > /etc/systemd/system/nats.service <<'EOF'
[Unit]
Description=NATS
After=network.target

[Service]
User=nats
Group=nats
ExecStart=/usr/local/bin/nats-server -c /etc/nats/nats.conf
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload >> "$LOG_FILE" 2>&1
systemctl enable --now nats >> "$LOG_FILE" 2>&1 || die "Failed to start NATS"
ok "NATS ready"

phase "Go ${GO_VERSION}"

if [[ ! -x /usr/local/go/bin/go ]] || ! /usr/local/go/bin/go version | grep -q "go${GO_VERSION}"; then
    run_cmd "Downloading Go ${GO_VERSION}..." wget -q "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" -O /tmp/go.tgz
    rm -rf /usr/local/go
    tar -C /usr/local -xzf /tmp/go.tgz >> "$LOG_FILE" 2>&1 || die "Failed to install Go"
    rm -f /tmp/go.tgz
else
    ok "Go ${GO_VERSION} already installed"
fi

cat > /etc/profile.d/go.sh <<'EOF'
export PATH=/usr/local/go/bin:$PATH
EOF
export PATH="/usr/local/go/bin:${PATH}"
/usr/local/go/bin/go version >> "$LOG_FILE" 2>&1 || die "Go is not working"
ok "Go ready: $(/usr/local/go/bin/go version | awk '{print $3}')"

phase "Build skylens-node"

[[ -d "${BUILD_DIR}/cmd/skylens-node" ]] || die "Source not found at ${BUILD_DIR}. Expected ${BUILD_DIR}/cmd/skylens-node"

if [[ -n "${SUDO_USER:-}" ]]; then
    chown -R "${SUDO_USER}:${SUDO_USER}" "$BUILD_DIR" >> "$LOG_FILE" 2>&1 || true
fi

TMP_BINARY="$(mktemp /tmp/skylens-node.XXXXXX)"
cd "$BUILD_DIR"
run_cmd "Building skylens-node..." /usr/local/go/bin/go build -trimpath -ldflags="-s -w" -o "$TMP_BINARY" ./cmd/skylens-node

install -o root -g root -m 0755 "$TMP_BINARY" "$BINARY_PATH"
setcap -r "$BINARY_PATH" >> "$LOG_FILE" 2>&1 || true
ok "Installed binary to ${BINARY_PATH}"

phase "TLS, config, and service"

if [[ ! -f "$CERT_FILE" || ! -f "$KEY_FILE" ]]; then
    info "Generating self-signed certificate..."
    openssl req -x509 -nodes -days 3650 -newkey rsa:2048 \
        -keyout "$KEY_FILE" \
        -out "$CERT_FILE" \
        -subj "/C=US/ST=NA/L=NA/O=Skylens/CN=$(hostname -f 2>/dev/null || hostname)" \
        >> "$LOG_FILE" 2>&1 || die "Failed to generate certificate"
fi
chmod 0644 "$CERT_FILE"
chmod 0640 "$KEY_FILE"
chown root:"$SERVICE_GROUP" "$CERT_FILE" "$KEY_FILE"

write_config
validate_config_yaml >> "$LOG_FILE" 2>&1 || die "Generated config.yaml is invalid"

write_service_unit
systemctl daemon-reload >> "$LOG_FILE" 2>&1
configure_selinux
ok "Config and service unit ready"

phase "Kernel/firewall tuning"

cat > /etc/sysctl.d/99-skylens.conf <<'EOF'
net.core.somaxconn = 8192
net.core.rmem_max = 16777216
net.core.wmem_max = 16777216
net.ipv4.tcp_rmem = 4096 87380 16777216
net.ipv4.tcp_wmem = 4096 65536 16777216
vm.swappiness = 1
EOF
sysctl --system >> "$LOG_FILE" 2>&1 || true

cat > /etc/security/limits.d/99-skylens.conf <<'EOF'
* soft nofile 65536
* hard nofile 65536
EOF

systemctl enable --now tuned >> "$LOG_FILE" 2>&1 || true
tuned-adm profile network-latency >> "$LOG_FILE" 2>&1 || true

systemctl enable --now firewalld >> "$LOG_FILE" 2>&1 || true
if systemctl is-active --quiet firewalld; then
    firewall-cmd --permanent --zone=public --add-port="${HTTPS_PORT}/tcp" >> "$LOG_FILE" 2>&1 || true
    firewall-cmd --reload >> "$LOG_FILE" 2>&1 || true
fi
ok "Tuning complete"

phase "Start and verify"

systemctl enable skylens-node >> "$LOG_FILE" 2>&1 || true
systemctl restart skylens-node >> "$LOG_FILE" 2>&1 || die "Failed to start skylens-node"

sleep 5
repair_auth_seed_if_needed

info "Waiting for skylens health endpoint..."
if ! wait_for_health 30; then
    journalctl -u skylens-node --no-pager -n 80 2>/dev/null | sed 's/^/    /'
    die "Skylens health endpoint did not come up"
fi

echo
for svc in postgresql-16 redis nats skylens-node; do
    if systemctl is-active --quiet "$svc"; then
        ok "${svc} running"
    else
        fail "${svc} not running"
        journalctl -u "$svc" --no-pager -n 20 2>/dev/null | sed 's/^/    /'
    fi
done

HEALTH="$(curl -kfsS "https://127.0.0.1:${HTTPS_PORT}/health" 2>/dev/null || true)"
ADMIN_COUNT="$(psql_app "SELECT COUNT(*) FROM users WHERE username='admin';" 2>/dev/null | xargs || echo 0)"
ROLE_COUNT="$(psql_app "SELECT COUNT(*) FROM roles;" 2>/dev/null | xargs || echo 0)"

PRIMARY_IP="$(hostname -I 2>/dev/null | awk '{print $1}')"
PRIMARY_IP="${PRIMARY_IP:-127.0.0.1}"

echo
echo -e "${GREEN}${BOLD}Install complete${NC}"
echo
echo "URL:        https://${PRIMARY_IP}:${HTTPS_PORT}/"
echo "Health:     ${HEALTH:-unavailable}"
echo "Binary:     ${BINARY_PATH}"
echo "Config:     ${CONFIG_FILE}"
echo "Service:    skylens-node"
echo "Postgres:   db=skylens user=skylens"
echo "Auth roles: ${ROLE_COUNT}"
echo "Admin rows: ${ADMIN_COUNT}"
echo
echo "Default web login should be:"
echo "  username: admin"
echo "  password: admin"
echo
echo "Useful checks:"
echo "  getcap ${BINARY_PATH}"
echo "  systemctl status skylens-node --no-pager"
echo "  journalctl -u skylens-node -n 100 --no-pager"
echo "  curl -k https://127.0.0.1:${HTTPS_PORT}/health"
echo
